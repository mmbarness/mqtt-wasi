# CloudAMQP (RabbitMQ, plain TCP on port 1883)
CLOUDAMQP_URL=amqps://user:pass@host.rmq3.cloudamqp.com/vhost

# HiveMQ Cloud (TLS on port 8883)
HIVEMQ_ADDR=your-cluster.s1.eu.hivemq.cloud:8883
HIVEMQ_USER=your-username
HIVEMQ_PASS=your-password

# Examples (any MQTT v5 broker)
MQTT_ADDR=127.0.0.1:1883
MQTT_USER=
MQTT_PASS=
